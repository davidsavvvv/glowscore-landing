{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/effects/**",
              "components/navigation/**",
              "components/score/**",
              "ui_kits/app/**",
              "ui_kits/shared/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Playfair Display|Inter))/i]",
        "message": "Font not provided by the design system. Available: Playfair Display, Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:gold|subtle|outline|soft)$/]",
        "message": "<Badge> variant must be one of 'gold' | 'subtle' | 'outline' | 'soft'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|block|disabled|iconLeft|iconRight|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, block, disabled, iconLeft, iconRight."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:gold|white|secondary|outline|ghost)$/]",
        "message": "<Button> variant must be one of 'gold' | 'white' | 'secondary' | 'outline' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:glass|glow|accent|padding|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: glass, glow, accent, padding."
      },
      {
        "selector": "JSXOpeningElement[name.name='GlowBlob'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|opacity|blur|style|key|ref|className|style|children)$/]",
        "message": "<GlowBlob> doesn't accept that prop. Declared props: size, opacity, blur, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|active|href|key|ref|className|style|children)$/]",
        "message": "<NavItem> doesn't accept that prop. Declared props: icon, active, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScoreChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|score|tone|key|ref|className|style|children)$/]",
        "message": "<ScoreChip> doesn't accept that prop. Declared props: label, score, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScoreChip'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:low|mid|high)$/]",
        "message": "<ScoreChip> tone must be one of 'low' | 'mid' | 'high'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScoreRing'] > JSXAttribute > JSXIdentifier[name!=/^(?:score|max|size|stroke|label|key|ref|className|style|children)$/]",
        "message": "<ScoreRing> doesn't accept that prop. Declared props: score, max, size, stroke, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='SubScore'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|max|key|ref|className|style|children)$/]",
        "message": "<SubScore> doesn't accept that prop. Declared props: label, value, max."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
